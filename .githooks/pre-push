#!/usr/bin/env bash
set -euo pipefail

echo "[pre-push] Running cargo fmt check..."
cargo fmt --all -- --check

is_tag_push=false
while read -r local_ref local_sha remote_ref remote_sha; do
	if [[ "$local_ref" == refs/tags/* ]]; then
		is_tag_push=true
		break
	fi
done

if [[ "$is_tag_push" == true ]]; then
	echo "[pre-push] Tag push detected, running cargo clippy..."
	cargo clippy --all-targets --all-features -- -D warnings
fi

echo "[pre-push] OK"
