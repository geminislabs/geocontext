# Kafka Broker Configuration
KAFKA_BROKERS=redpanda:9092
KAFKA_GROUP_ID=geocontext-consumer
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=siscom-producer
KAFKA_PASSWORD=producerpassword
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT

# Kafka Topics
KAFKA_INPUT_TOPIC=siscom-minimal
KAFKA_OUTPUT_TOPIC=siscom-geocontext

# Consumer Configuration
KAFKA_CONSUMER_FETCH_MIN_BYTES=1024
KAFKA_CONSUMER_FETCH_WAIT_MAX_MS=100
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=300000
KAFKA_CONSUMER_SESSION_TIMEOUT_MS=45000
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false

# Producer Configuration
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_RETRIES=5
KAFKA_PRODUCER_IDEMPOTENT=true

# Consumer-Producer Linking
COMMIT_ON_PRODUCE_SUCCESS=true

# Circuit Breaker Configuration
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000

# Logging
RUST_LOG=info,geocontext=debug
